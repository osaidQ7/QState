   "source": [
    "import numpy as np\n",
    "from qiskit.visualization import plot_bloch_vector\n",
    "\n",
    "coord = 1\n",
    "state = [1, np.pi/2, 0]\n",
    "plot_bloch_vector(state, title=f\"Qubit with state {state}\", coord_type='cartesian' if coord==0 else 'spherical')\n",
    "\n"
   ]
  }
